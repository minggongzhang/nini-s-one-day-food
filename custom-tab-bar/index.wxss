/* custom-tab-bar/index.wxss */
.custom-tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 999;
  background: #ffffff;
  border-top: 1rpx solid #D5C0C4;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.tab-bar-list {
  display: flex;
  align-items: center;
  height: 100rpx;
}

.tab-bar-item {
  flex: 1;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 8rpx;
}

.tab-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 4rpx;
}

.tab-text {
  font-size: 20rpx;
  line-height: 1;
  color: #B0949A;
}

.tab-bar-item.active .tab-text {
  color: #FF8A9E;
}

.safe-area-bottom {
  height: env(safe-area-inset-bottom);
}
