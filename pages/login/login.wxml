<!--login.wxml-->
<view class="login-container">
  <view class="header">
    <view class="logo-icon">
      <image class="heart" src="/images/emoji/heart.png" />
    </view>
    <text class="title">妮妮的一日三餐</text>
    <view class="subtitle">选择角色，开始你们的美食之旅 <image class="inline-icon" src="/images/emoji/red-heart.png" /></view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-wrapper" wx:if="{{ loadingUserInfo }}">
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 登录表单 -->
  <view class="login-form" wx:else>
    <view class="avatar-section">
      <button
        class="avatar-wrapper-btn"
        open-type="chooseAvatar"
        bindchooseavatar="onChooseAvatar"
      >
        <view class="avatar-wrapper" wx:if="{{ avatarUrl }}">
          <image class="avatar" src="{{ avatarUrl }}" mode="aspectFill"></image>
        </view>
        <view class="avatar-btn" wx:else>
          <image class="avatar-icon" src="/images/emoji/person.png" />
        </view>
        <text class="avatar-tip">{{ avatarUrl ? '点击更换头像' : '点击选择头像' }}</text>
      </button>
    </view>

    <view class="input-section">
      <input 
        class="nickname-input"
        type="nickname"
        placeholder="请输入昵称"
        value="{{ nickname }}"
        bindinput="onNicknameInput"
      />
    </view>

    <view class="role-section">
      <text class="role-label">选择你的角色</text>
      <view class="role-options" wx:if="{{ !hasExistingRole }}">
        <view 
          class="role-card {{ selectedRole === 'girlfriend' ? 'active' : '' }}"
          bindtap="onRoleSelect"
          data-role="girlfriend"
        >
          <image class="role-emoji" src="/images/emoji/girl.png" />
          <text class="role-name">女朋友</text>
          <text class="role-desc">点菜下单</text>
        </view>
        <view 
          class="role-card {{ selectedRole === 'boyfriend' ? 'active' : '' }}"
          bindtap="onRoleSelect"
          data-role="boyfriend"
        >
          <image class="role-emoji" src="/images/emoji/cook.png" />
          <text class="role-name">男朋友</text>
          <text class="role-desc">接单制作</text>
        </view>
      </view>
      <view class="role-fixed" wx:else>
        <view class="role-card active">
          <image class="role-emoji" src="{{ selectedRole === 'girlfriend' ? '/images/emoji/princess.png' : '/images/emoji/cook.png' }}" />
          <text class="role-name">{{ selectedRole === 'girlfriend' ? '女朋友' : '男朋友' }}</text>
          <text class="role-desc">{{ selectedRole === 'girlfriend' ? '点菜下单' : '接单制作' }}</text>
        </view>
        <text class="role-tip">角色已固定，无法更改</text>
      </view>
    </view>

    <button class="login-btn" bindtap="handleLogin" loading="{{ logging }}" disabled="{{ logging }}">
      <text class="login-text">{{ logging ? '登录中...' : '开始享用美食' }}</text>
    </button>
  </view>

  <view class="footer">
    <view class="copyright">Made with <image class="inline-icon-sm" src="/images/emoji/red-heart.png" /> for NiNi</view>
  </view>
</view>
