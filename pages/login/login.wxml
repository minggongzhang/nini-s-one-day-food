<!--login.wxml-->
<view class="login-container">
  <view class="header">
    <view class="logo-icon">
      <text class="heart">💕</text>
    </view>
    <text class="title">妮妮的一日三餐</text>
    <text class="subtitle">选择角色，开始你们的美食之旅 ❤️</text>
  </view>

  <view class="login-form">
    <view class="avatar-section">
      <view class="avatar-wrapper" wx:if="{{ avatarUrl }}">
        <image class="avatar" src="{{ avatarUrl }}" mode="aspectFill"></image>
      </view>
      <button 
        class="avatar-btn" 
        wx:else 
        open-type="chooseAvatar" 
        bindchooseavatar="onChooseAvatar"
      >
        <text class="avatar-icon">👤</text>
      </button>
      <text class="avatar-tip">点击选择头像</text>
    </view>

    <view class="input-section">
      <input 
        class="nickname-input"
        type="nickname"
        placeholder="请输入昵称"
        value="{{ nickname }}"
        bindinput="onNicknameInput"
      />
    </view>

    <view class="role-section">
      <text class="role-label">选择你的角色</text>
      <view class="role-options">
        <view 
          class="role-card {{ selectedRole === 'girlfriend' ? 'active' : '' }}"
          bindtap="onRoleSelect"
          data-role="girlfriend"
        >
          <text class="role-emoji">👸</text>
          <text class="role-name">女朋友</text>
          <text class="role-desc">点菜下单</text>
        </view>
        <view 
          class="role-card {{ selectedRole === 'boyfriend' ? 'active' : '' }}"
          bindtap="onRoleSelect"
          data-role="boyfriend"
        >
          <text class="role-emoji">🤴</text>
          <text class="role-name">男朋友</text>
          <text class="role-desc">接单制作</text>
        </view>
      </view>
    </view>

    <button class="login-btn" bindtap="handleLogin" loading="{{ logging }}" disabled="{{ logging }}">
      <text class="login-text">{{ logging ? '登录中...' : '开始享用美食' }}</text>
    </button>
  </view>

  <view class="footer">
    <text class="copyright">Made with ❤️ for NiNi</text>
  </view>
</view>
