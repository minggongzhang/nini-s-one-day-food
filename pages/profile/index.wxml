<!--pages/profile/index.wxml-->
<view class="page-container">
  <!-- 用户信息卡 -->
  <view class="user-card">
    <view class="user-row">
      <image class="user-avatar" src="{{ userInfo.avatarUrl }}" mode="aspectFill" wx:if="{{ userInfo.avatarUrl }}"></image>
      <view class="user-avatar-placeholder" wx:else>
        <text class="placeholder-icon">👤</text>
      </view>
      <view class="user-info">
        <view class="user-name-row">
          <text class="user-name">{{ userInfo.nickname || '未登录' }}</text>
          <text class="role-badge {{ userInfo.role === 'boyfriend' ? 'role-boy' : 'role-girl' }}">
            {{ userInfo.role === 'boyfriend' ? '🤴 男朋友' : '👸 女朋友' }}
          </text>
        </view>
        <text class="user-id">ID: {{ shortOpenId }}</text>
      </view>
    </view>
  </view>

  <!-- 妮妮币余额卡 -->
  <view class="balance-card">
    <view class="balance-info">
      <text class="balance-label">妮妮币余额</text>
      <text class="balance-amount">{{ userInfo.balance || 0 }}</text>
    </view>
    <view class="balance-actions">
      <view class="recharge-btn" wx:if="{{ userInfo.role === 'boyfriend' }}" bindtap="onRechargeTap">
        <text>充值</text>
      </view>
      <view class="balance-tip" wx:else>
        让男朋友给你充值吧~
      </view>
    </view>
  </view>

  <!-- 快捷统计 -->
  <view class="stats-row">
    <view class="stat-item" bindtap="goToOrders">
      <text class="stat-num">{{ stats.totalOrders }}</text>
      <text class="stat-label">全部订单</text>
    </view>
    <view class="stat-item" bindtap="goToOrders">
      <text class="stat-num">{{ stats.pendingOrders }}</text>
      <text class="stat-label">待处理</text>
    </view>
    <view class="stat-item" bindtap="goToOrders">
      <text class="stat-num">{{ stats.completedOrders }}</text>
      <text class="stat-label">已完成</text>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-list">
    <view class="menu-item" bindtap="goToOrders">
      <text class="menu-icon">📋</text>
      <text class="menu-text">我的订单</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToFood">
      <text class="menu-icon">🍔</text>
      <text class="menu-text">去点餐</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onLogout">
      <text class="menu-icon">🚪</text>
      <text class="menu-text">退出登录</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>

<!-- 充值弹窗 -->
<view class="modal-mask" wx:if="{{ showRechargeModal }}" bindtap="onCloseRecharge"></view>
<view class="recharge-modal" wx:if="{{ showRechargeModal }}">
  <view class="modal-title">妮妮币充值</view>

  <!-- 充值目标选择 -->
  <view class="recharge-target">
    <view
      class="target-chip {{ rechargeTarget === 'self' ? 'active' : '' }}"
      bindtap="onTargetSelect"
      data-target="self"
    >给自己</view>
    <view
      class="target-chip {{ rechargeTarget === 'girlfriend' ? 'active' : '' }}"
      bindtap="onTargetSelect"
      data-target="girlfriend"
    >给妮妮 👸</view>
  </view>

  <!-- 充值金额 -->
  <view class="recharge-amounts">
    <view
      class="amount-chip {{ rechargeAmount === item ? 'active' : '' }}"
      wx:for="{{ rechargeOptions }}"
      wx:key="*this"
      data-amount="{{ item }}"
      bindtap="onAmountSelect"
    >
      {{ item }}
    </view>
  </view>
  <view class="custom-amount-row">
    <input
      class="custom-amount-input"
      type="number"
      placeholder="自定义金额"
      value="{{ customAmount }}"
      bindinput="onCustomAmountInput"
    />
    <text class="amount-unit">妮妮币</text>
  </view>
  <view class="modal-btns">
    <view class="modal-btn cancel" bindtap="onCloseRecharge">取消</view>
    <view class="modal-btn confirm" bindtap="onConfirmRecharge">{{ recharging ? '充值中...' : '确认充值' }}</view>
  </view>
</view>
