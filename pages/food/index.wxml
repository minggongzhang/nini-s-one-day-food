<!--pages/food/index.wxml-->
<view class="page-container">
  <scroll-view class="filter-tabs" scroll-x scroll-with-animation show-scrollbar="{{ true }}">
    <view 
      class="tab-item {{ activeCategory === item.name ? 'active' : '' }}" 
      wx:for="{{ categories }}" 
      wx:key="name"
      data-category="{{ item.name }}"
      bindtap="handleCategoryChange"
    >
      {{ item.name }}
    </view>
  </scroll-view>

  <view class="food-list" wx:if="{{ !loading && foods.length > 0 }}">
    <view class="food-item" wx:for="{{ foods }}" wx:key="_id">
      <view class="food-image">
        <image wx:if="{{ item.imageUrl }}" src="{{ item.imageUrl }}" mode="aspectFill" class="food-img" />
        <image wx:else class="food-icon" src="{{ item.iconPath }}" mode="aspectFit" />
      </view>
      <view class="food-content">
        <view class="food-name-row">
          <text class="food-name">{{ item.name }}</text>
          <text class="custom-badge" wx:if="{{ item.isCustom }}">{{ nickname || '我' }}想吃</text>
        </view>
        <text class="food-desc">{{ item.description }}</text>
        <view class="taste-tags" wx:if="{{ item.tasteTags && item.tasteTags.length > 0 }}">
          <text class="taste-tag" wx:for="{{ item.tasteTags }}" wx:for-item="tag" wx:key="*this">{{ tag }}</text>
        </view>
        <text class="food-price">¥{{ item.price }}</text>
        <button class="add-btn" data-index="{{ index }}" bindtap="handleAddToCart">加入购物车</button>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:if="{{ !loading && foods.length === 0 }}">
    <image class="empty-icon" src="/images/emoji/plate.png" />
    <text class="empty-text">暂无菜品，快去添加吧~</text>
  </view>

  <view class="loading-state" wx:if="{{ loading }}">
    <image class="loading-icon" src="/images/emoji/hourglass.png" />
    <text class="loading-text">加载中...</text>
  </view>
</view>

<view class="fab-btn" bindtap="handleAddFood">
  <text class="fab-icon">+</text>
  <text class="fab-text">我想吃</text>
</view>

<view class="cart-bar" wx:if="{{ cartCount > 0 }}">
  <view class="cart-icon" bindtap="toggleCartPopup">
    <image class="cart-icon-img" src="/images/emoji/cart.png" />
    <view class="cart-badge">{{ cartCount }}</view>
  </view>
  <view class="cart-info" bindtap="toggleCartPopup">
    <text class="cart-total">¥{{ cartTotal }}</text>
    <text class="cart-desc">已选{{ cartCount }}件商品</text>
  </view>
  <button class="submit-btn" bindtap="handleCheckout">去结算</button>
</view>

<view class="cart-mask" wx:if="{{ showCartPopup }}" bindtap="handleMaskTap"></view>
<view class="cart-popup" wx:if="{{ showCartPopup }}">
  <view class="popup-header">
    <text class="popup-title">购物车</text>
    <text class="popup-clear" bindtap="handleClearCart">清空</text>
  </view>
  <scroll-view class="popup-content" scroll-y>
    <view class="cart-item" wx:for="{{ cart }}" wx:key="_id">
      <view class="cart-item-icon"><image class="cart-item-icon-img" src="{{ item.iconPath }}" mode="aspectFit" /></view>
      <view class="cart-item-info">
        <text class="cart-item-name">{{ item.name }}</text>
        <text class="cart-item-price">¥{{ item.price }}</text>
      </view>
      <view class="cart-item-actions">
        <view class="qty-btn" bindtap="handleDecreaseQty" data-id="{{ item._id }}">-</view>
        <text class="qty-num">{{ item.quantity }}</text>
        <view class="qty-btn" bindtap="handleIncreaseQty" data-id="{{ item._id }}">+</view>
      </view>
      <view class="cart-item-delete" bindtap="handleRemoveItem" data-id="{{ item._id }}">删除</view>
    </view>
  </scroll-view>
  <view class="popup-footer">
    <view class="footer-balance">余额：{{ userBalance }} 妮妮币</view>
    <text class="footer-total">合计：¥{{ cartTotal }}</text>
  </view>
</view>
